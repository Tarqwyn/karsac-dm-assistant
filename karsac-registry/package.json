{
  "name": "karsac-registry",
  "version": "1.0.0",
  "description": "Deterministic metadata index over Karsac canon Markdown files",
  "type": "module",
  "scripts": {
    "karsac:index": "tsx src/build-index.ts",
    "karsac:lookup": "tsx src/lookup.ts",
    "karsac:show": "tsx src/show.ts",
    "karsac:ask": "tsx src/ask.ts",
    "gateway": "node --import tsx src/gateway/server.ts",
    "karsac:propose": "node --import tsx src/commands/propose.ts",
    "karsac:summarise-proposal": "node --import tsx src/commands/summariseProposal.ts",
    "karsac:validate-proposals": "tsx src/commands/validateProposals.ts",
    "karsac:list-proposals": "tsx src/commands/listProposals.ts",
    "karsac:promote-proposal": "tsx src/commands/promoteProposal.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-glob": "^3.3.2",
    "gray-matter": "^4.0.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
