{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karsac.local/schemas/state/chapters/chapter-facts.json",
  "type": "object",
  "unevaluatedProperties": false,
  "allOf": [
    {
      "$ref": "https://karsac.local/schemas/state/_shared.json#/$defs/chapterFile"
    },
    {
      "type": "object",
      "required": [
        "facts"
      ],
      "properties": {
        "facts": {
          "type": "array",
          "items": {
            "$ref": "https://karsac.local/schemas/state/_shared.json#/$defs/chapterFact"
          }
        }
      }
    }
  ]
}
