{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karsac.local/schemas/state/chapters/chapter-handouts.json",
  "type": "object",
  "unevaluatedProperties": false,
  "allOf": [
    {
      "$ref": "https://karsac.local/schemas/state/_shared.json#/$defs/chapterFile"
    },
    {
      "type": "object",
      "required": [
        "handouts"
      ],
      "properties": {
        "handouts": {
          "type": "array",
          "items": {
            "$ref": "https://karsac.local/schemas/state/_shared.json#/$defs/chapterHandout"
          }
        }
      }
    }
  ]
}
