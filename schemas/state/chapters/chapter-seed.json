{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://karsac.local/schemas/state/chapters/chapter-seed.json",
  "type": "object",
  "unevaluatedProperties": false,
  "required": [
    "beats",
    "scenes"
  ],
  "properties": {
    "beats": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "scene",
          "desc"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "scene": {
            "type": "string",
            "minLength": 1
          },
          "desc": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "scenes": {
      "type": "array",
      "items": {
        "$ref": "https://karsac.local/schemas/state/_shared.json#/$defs/chapterScene"
      }
    }
  }
}
